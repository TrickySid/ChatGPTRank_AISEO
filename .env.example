# Server-side only:
# Set this in your hosting provider (Vercel/Netlify/Cloudflare) as an environment variable.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: allow list of comma-separated origins for CORS (e.g. https://yourdomain.com,https://www.yourdomain.com)
ALLOWED_ORIGINS=

# Optional: basic rate limit (per IP)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
